[Desktop Entry]
Name=Fonts
Exec=gnome-font-viewer %u
Icon=org.gnome.font-viewer
Type=Application
DBusActivatable=true
StartupNotify=true
NoDisplay=true
Categories=GTK;GNOME;Utility;
Keywords=fonts;fontface;
MimeType=application/x-font-ttf;application/x-font-pcf;application/x-font-type1;application/x-font-otf;font/ttf;font/otf;font/woff;font/collection;
